# Vite Environment Variables
# Copy this file to .env.local and add your actual values

# Google Gemini API Configuration
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-2.0-flash-exp

# API Configuration
VITE_API_BASE_URL=http://localhost:5173
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_VOICE_INPUT=true
VITE_ENABLE_DOCUMENT_REVIEW=true

# Environment
VITE_NODE_ENV=development

# Legal Platform Configuration
VITE_EMERGENCY_HOTLINE=+916230244977
VITE_SUPPORT_EMAIL=support@legalplatform.com

# Rate Limiting (requests per minute)
VITE_API_RATE_LIMIT=60