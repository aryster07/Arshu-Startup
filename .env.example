# Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# API Configuration
REACT_APP_API_URL=http://localhost:5000

# Google OAuth2
# Get these from Google Cloud Console
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here

# Facebook OAuth2  
# Get these from Facebook Developers
REACT_APP_FACEBOOK_APP_ID=your_facebook_app_id_here

# Apple Sign In
# Get these from Apple Developer Portal
REACT_APP_APPLE_CLIENT_ID=your_apple_client_id_here
REACT_APP_APPLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Environment
REACT_APP_ENVIRONMENT=development

# Optional: Analytics and monitoring
REACT_APP_GOOGLE_ANALYTICS_ID=your_ga_id_here
REACT_APP_SENTRY_DSN=your_sentry_dsn_here