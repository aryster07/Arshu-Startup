# Security Environment Variables
# CRITICAL: Never commit this file to version control
# Use 1Password or Doppler for production secrets management

# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database Configuration (MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/arshu-legal?retryWrites=true&w=majority
MONGODB_URI_TEST=mongodb+srv://username:password@cluster.mongodb.net/arshu-legal-test?retryWrites=true&w=majority

# JWT Security
JWT_SECRET=your-ultra-secure-jwt-secret-minimum-256-bits
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your-ultra-secure-refresh-secret-minimum-256-bits
JWT_REFRESH_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Encryption Keys
ENCRYPTION_KEY=your-32-character-encryption-key
CRYPTO_SECRET=your-crypto-secret-for-hashing

# Authentication Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-minimum-64-characters
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Two-Factor Authentication
TOTP_SERVICE_NAME=Arshu Legal Platform
TOTP_ISSUER=Arshu Legal

# OAuth2 Configuration
# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Facebook OAuth2
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/v1/auth/facebook/callback

# Apple Sign In
APPLE_TEAM_ID=your-apple-team-id
APPLE_CLIENT_ID=your-apple-client-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=./keys/AuthKey_[KeyID].p8
APPLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/apple/callback

# Frontend URLs
CLIENT_URL=http://localhost:3000
LAWYER_PORTAL_URL=http://localhost:3000/lawyer
ADMIN_PORTAL_URL=http://localhost:3000/admin

# Email Configuration (for notifications)
EMAIL_FROM=noreply@arshulegal.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Stripe Payment Processing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-exp

# Security Monitoring
SENTRY_DSN=your-sentry-dsn-here
NEWRELIC_LICENSE_KEY=your-newrelic-license-key

# File Upload Security
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.txt,.jpg,.jpeg,.png

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
CORS_CREDENTIALS=true

# Security Headers
TRUST_PROXY=false
SECURE_COOKIES=false

# API Rate Limiting
API_RATE_LIMIT_WINDOW=900000
API_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW=900000
AUTH_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=5242880
LOG_FILE_MAX_FILES=5

# Cache Configuration
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30

# Legal Compliance
GDPR_ENABLED=true
DATA_RETENTION_DAYS=365
AUDIT_LOG_ENABLED=true

# Development/Testing
DEV_MODE=true
MOCK_PAYMENTS=true
SKIP_EMAIL_VERIFICATION=false