# Production Environment Variables for Vercel
# These will be set in Vercel dashboard

# API Configuration (will be set via Vercel environment variables)
VITE_API_URL=https://your-api-domain.vercel.app
VITE_ENVIRONMENT=production

# Note: Add these environment variables in your Vercel dashboard:
# 1. Go to your project settings in Vercel
# 2. Navigate to Environment Variables
# 3. Add:
#    - VITE_API_URL with your production API URL
#    - VITE_ENVIRONMENT with value "production"